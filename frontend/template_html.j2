<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RAG Assistant</title>
</head>
<body>
    <h2>Prompt</h2>

<h2>Instructions</h2>
<div>
  Use the following pieces of context to answer the question at the end.
</div>

<h2>History</h2>
{% for entry in history %}
  <div>
    <strong>{{ entry[0] }}</strong>: {{ entry[1] }}
  </div>
{% endfor %}

<h2>Context</h2>
{% for doc in documents %}
  <details>
    <summary>Doc {{ loop.index }}: {{ doc[:100] }}...</summary>
    <div>{{ doc }}</div>
  </details>
{% endfor %}

<h2>Query</h2>
<div>{{ query }}</div>
    
</body>
</html>